# Agente Scratch — Variables de entorno
# Copia este archivo como .env y completa los valores

# Clave de API de Google Gemini (obligatoria)
# Consigue tu clave gratis en: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Credenciales de Scratch (opcionales — solo para subida automatica)
SCRATCH_USERNAME=
SCRATCH_PASSWORD=

# Configuracion del agente LangGraph
MAX_REINTENTOS=3
MODELO_AGENTE=gemini-2.5-flash

# Puerto del servidor MCP en modo HTTP (opcional)
MCP_PORT=8000
